# Copy to apps/web/.env.local (gitignored) and fill in. Build + runtime read this.

# iron-session signing key — must be at least 32 chars.
# Generate with: openssl rand -hex 32
SESSION_SECRET="replace-with-strong-random-32-plus-char-secret"

# Wallet connection uses @mysten/dapp-kit, which auto-detects installed Sui
# wallets via the Wallet Standard — no project id needed.

# ─── chat console (server-side agent) ──
# LLM brain for /api/chat. Without it, chat reports "brain not configured".
OPENAI_API_KEY=""
# Optional overrides (defaults: api.openai.com/v1, gpt-4o-mini).
# LYRA_LLM_BASE_URL=""
# LYRA_LLM_MODEL="gpt-4o-mini"

# ─── policy cap for value-moving actions ──
# Writes are signed by the USER'S OWN connected wallet (client-side) — the
# server holds NO key. This is just the deterministic per-tx guardrail: lyra
# refuses to prepare a native-SUI action above this many SUI.
LYRA_POLICY_MAX_PER_TX_SUI="25"
# LYRA_SIGNER_PRIVATE_KEY is no longer used for the web console (client-signed).
